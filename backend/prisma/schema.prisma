generator client {
  provider = "prisma-client-js"
  previewFeatures = ["omitApi"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Department {
  id            String         @id @default(uuid())
  name          String         @unique
  hrId          String?        @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  hr            User?          @relation("DeptHR", fields: [hrId], references: [id], onDelete: SetNull)
  employees     User[]         @relation("DeptEmployees")
  leaveRequests LeaveRequest[]
}

model User {
  id                   String                @id @default(uuid())
  email                String                @unique
  password             String
  name                 String
  employeeCode         String                @unique
  role                 Role                  @default(EMPLOYEE)
  phone                String?
  bio                  String?
  profileImage         String?
  departmentId         String?
  shift                String                @default("B") // A: 9-6, B: 10-7
  monthlySalary        Float                 @default(0)
  emailVerified        Boolean               @default(true) // Default to true for existing real users
  otp                  String?
  otpExpires           DateTime?
  needsPasswordChange  Boolean               @default(false)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  attendances          Attendance[]
  auditLogs            AuditLog[]
  biometricAttendances BiometricAttendance[]
  DailyTask            DailyTask[]
  managedDepartment    Department?           @relation("DeptHR")
  emailLogs            EmailLog[]
  leaveBalances        LeaveBalance[]
  leaveRequests        LeaveRequest[]
  notifications        Notification[]
  refreshTokens        RefreshToken[]
  TaskSubmission       TaskSubmission[]
  department           Department?           @relation("DeptEmployees", fields: [departmentId], references: [id])
  @@index([role])
  @@index([departmentId])
}

model LeaveType {
  id            String         @id @default(uuid())
  name          String         @unique
  daysAllowed   Int
  leaveBalances LeaveBalance[]
  leaveRequests LeaveRequest[]
}

model LeaveBalance {
  id          String    @id @default(uuid())
  userId      String
  leaveTypeId String
  balance     Float
  used        Float     @default(0)
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, leaveTypeId])
}

model LeaveRequest {
  id                   String      @id @default(uuid())
  userId               String
  leaveTypeId          String
  departmentId         String?
  startDate            DateTime
  endDate              DateTime
  totalDays            Float
  durationType         String      @default("FULL_DAY")
  reason               String
  status               LeaveStatus @default(PENDING_HR)
  approvedById         String?
  comments             String?
  hrApprovedAt         DateTime?
  superadminApprovedAt DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  leaveType            LeaveType   @relation(fields: [leaveTypeId], references: [id])
  user                 User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  department           Department? @relation(fields: [departmentId], references: [id])
  @@index([userId])
  @@index([status])
  @@index([startDate])
}

model Attendance {
  id           String    @id @default(uuid())
  userId       String
  date         DateTime  @db.Date
  checkIn      DateTime?
  checkOut     DateTime?
  status       String
  workingHours Float     @default(0)
  breakTime    Float     @default(0)
  deficit      Float     @default(0)
  leaveDeducted Float    @default(0)
  shiftType    String?
  overtime     Float     @default(0)
  isManual     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model BiometricAttendance {
  id               String             @id @default(uuid())
  userId           String
  employeeCode     String
  timestamp        DateTime
  deviceIP         String?
  verificationMode Int?               @default(1)
  deviceLogId      String?
  syncLogId        String?
  createdAt        DateTime           @default(now())
  syncLog          AttendanceSyncLog? @relation(fields: [syncLogId], references: [id])
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([createdAt])
  @@index([isRead])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model EmailLog {
  id         String   @id @default(uuid())
  userId     String
  subject    String
  sentStatus Boolean
  error      String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemSettings {
  id                  String   @id @default(uuid())
  biometricDeviceIP   String?
  syncInterval        String?
  workStartTime       String   @default("10:00")
  workEndTime         String   @default("19:00")
  gracePeriod         Int      @default(15)
  wfhMonthlyLimit     Int      @default(4)
  wfhConsecutiveLimit Int      @default(2)
  updatedAt           DateTime @updatedAt
}

model AttendanceSyncLog {
  id           String                @id @default(uuid())
  syncedAt     DateTime              @default(now())
  status       String
  recordsCount Int
  errorMessage String?
  records      BiometricAttendance[]
}

model Holiday {
  id        String   @id @default(uuid())
  date      DateTime @unique @db.Date
  name      String
  type      String   @default("GOVERNMENT") // GOVERNMENT, OPTIONAL, etc.
  createdAt DateTime @default(now())
}

model DailyTask {
  id             String           @id
  title          String
  description    String
  deadline       DateTime
  assignedToId   String
  status         String           @default("PENDING")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  User           User             @relation(fields: [assignedToId], references: [id], onDelete: Cascade)
  TaskSubmission TaskSubmission[]
}

model TaskSubmission {
  id          String    @id
  taskId      String
  userId      String
  proofUrl    String?
  comments    String?
  submittedAt DateTime  @default(now())
  DailyTask   DailyTask @relation(fields: [taskId], references: [id])
  User        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  SUPER_ADMIN
  ADMIN
  HR
  EMPLOYEE
}

enum LeaveStatus {
  PENDING
  PENDING_HR
  PENDING_SUPERADMIN
  HR_APPROVED
  FINAL_APPROVED
  REJECTED_BY_HR
  REJECTED_BY_SUPERADMIN
  APPROVED
  REJECTED
  CANCELLED
}

model PendingUser {
  id            String   @id @default(uuid())
  name          String
  email         String
  password      String
  role          String
  departmentId  String?
  employeeCode  String
  shift         String   @default("B")
  monthlySalary Float    @default(0)
  otp           String
  expires       DateTime
  createdAt     DateTime @default(now())
}

model PasswordReset {
  id        String   @id @default(uuid())
  email     String
  otp       String
  expires   DateTime
  createdAt DateTime @default(now())
}

