generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["omitApi"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Department {
  id            String         @id @default(uuid())
  name          String         @unique
  hrId          String?        @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  hr            User?          @relation("DeptHR", fields: [hrId], references: [id])
  leaveRequests LeaveRequest[]
  employees     User[]         @relation("DeptEmployees")
}

model User {
  id                   String                @id @default(uuid())
  email                String                @unique
  password             String
  name                 String
  employeeCode         String                @unique
  role                 Role                  @default(EMPLOYEE)
  departmentId         String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  bio                  String?
  emailVerified        Boolean               @default(true)
  monthlySalary        Float                 @default(0)
  needsPasswordChange  Boolean               @default(false)
  otp                  String?
  otpExpires           DateTime?
  phone                String?
  profileImage         String?
  shift                String                @default("B")
  attendances          Attendance[]
  auditLogs            AuditLog[]
  biometricAttendances BiometricAttendance[]
  DailyTask            DailyTask[]
  managedDepartment    Department?           @relation("DeptHR")
  emailLogs            EmailLog[]
  leaveBalances        LeaveBalance[]
  leaveRequests        LeaveRequest[]
  notifications        Notification[]
  refreshTokens        RefreshToken[]
  TaskSubmission       TaskSubmission[]
  department           Department?           @relation("DeptEmployees", fields: [departmentId], references: [id])
  wfhRequests          WfhRequest[]
  workLogs             WorkLog[]

  @@index([role])
  @@index([departmentId])
}

model WorkLog {
  id           String   @id @default(uuid())
  userId       String
  date         DateTime @db.Date
  startTime    DateTime
  endTime      DateTime
  totalHours   Float
  workType     String   // Shoot / Editing / Travel / Meeting / Other
  location     String   // On-site / Client Location / Remote
  description  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deviceInfo   String?
  ipAddress    String?
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

model LeaveType {
  id            String         @id @default(uuid())
  name          String         @unique
  daysAllowed   Int
  leaveBalances LeaveBalance[]
  leaveRequests LeaveRequest[]
}

model LeaveBalance {
  id          String    @id @default(uuid())
  userId      String
  leaveTypeId String
  balance     Float
  used        Float     @default(0)
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, leaveTypeId])
}

model LeaveRequest {
  id                   String      @id @default(uuid())
  userId               String
  leaveTypeId          String
  startDate            DateTime
  endDate              DateTime
  reason               String
  status               LeaveStatus @default(PENDING_HR)
  approvedById         String?
  comments             String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  departmentId         String?
  durationType         String      @default("FULL_DAY")
  hrApprovedAt         DateTime?
  superadminApprovedAt DateTime?
  totalDays            Float
  department           Department? @relation(fields: [departmentId], references: [id])
  leaveType            LeaveType   @relation(fields: [leaveTypeId], references: [id])
  user                 User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([startDate])
}

model Attendance {
  id            String    @id @default(uuid())
  userId        String
  date          DateTime  @db.Date
  checkIn       DateTime?
  checkOut      DateTime?
  status        String
  workingHours  Float     @default(0)
  overtime      Float     @default(0)
  isManual      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  breakTime     Float     @default(0)
  deficit       Float     @default(0)
  leaveDeducted Float     @default(0)
  shiftType     String?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model BiometricAttendance {
  id               String             @id @default(uuid())
  userId           String
  employeeCode     String
  timestamp        DateTime
  deviceIP         String?
  syncLogId        String?
  createdAt        DateTime           @default(now())
  deviceLogId      String?
  verificationMode Int?               @default(1)
  syncLog          AttendanceSyncLog? @relation(fields: [syncLogId], references: [id])
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([isRead])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model EmailLog {
  id         String   @id @default(uuid())
  userId     String
  subject    String
  sentStatus Boolean
  error      String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemSettings {
  id                   String   @id @default(uuid())
  biometricDeviceIP    String?
  syncInterval         String?
  workStartTime        String   @default("10:00")
  workEndTime          String   @default("19:00")
  gracePeriod          Int      @default(15)
  updatedAt            DateTime @updatedAt
  wfhConsecutiveLimit  Int      @default(2)
  wfhMonthlyLimit      Int      @default(4)
  totalLeaveAllocation Int      @default(18)
}

model AttendanceSyncLog {
  id           String                @id @default(uuid())
  syncedAt     DateTime              @default(now())
  status       String
  recordsCount Int
  errorMessage String?
  records      BiometricAttendance[]
}

model Holiday {
  id        String   @id @default(uuid())
  date      DateTime @unique @db.Date
  name      String
  type      String   @default("GOVERNMENT")
  createdAt DateTime @default(now())
}

model DailyTask {
  id             String           @id
  title          String
  description    String
  deadline       DateTime
  assignedToId   String
  status         String           @default("PENDING")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  User           User             @relation(fields: [assignedToId], references: [id], onDelete: Cascade)
  TaskSubmission TaskSubmission[]
}

model TaskSubmission {
  id          String    @id
  taskId      String
  userId      String
  proofUrl    String?
  comments    String?
  submittedAt DateTime  @default(now())
  DailyTask   DailyTask @relation(fields: [taskId], references: [id])
  User        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PendingUser {
  id            String   @id @default(uuid())
  name          String
  email         String
  password      String
  role          String
  departmentId  String?
  employeeCode  String
  shift         String   @default("B")
  monthlySalary Float    @default(0)
  otp           String
  expires       DateTime
  createdAt     DateTime @default(now())
}

model PasswordReset {
  id        String   @id @default(uuid())
  email     String
  otp       String
  expires   DateTime
  createdAt DateTime @default(now())
}

model WfhRequest {
  id        String   @id @default(uuid())
  userId    String
  wfhDate   DateTime @db.Date
  status    String   @default("AUTO_APPROVED")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  reason    String   @default("")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, wfhDate])
  @@index([userId])
  @@index([wfhDate])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  HR
  EMPLOYEE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  PENDING_HR
  PENDING_SUPERADMIN
  HR_APPROVED
  FINAL_APPROVED
  REJECTED_BY_HR
  REJECTED_BY_SUPERADMIN
  CANCELLED
}
