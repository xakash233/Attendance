# REST API (Vercel serverless is fine)
NEXT_PUBLIC_API_URL=https://backend-delta-eight-49.vercel.app/api

# --- Socket.io (must hit Node `src/index.js`, not Vercel api/index.js) ---

# Recommended: proxy /socket.io on the HRMS site to your Node server
SOCKET_PROXY_TARGET=https://your-node-server.example.com:5001
NEXT_PUBLIC_SOCKET_SAME_ORIGIN=true
NEXT_PUBLIC_ENABLE_SOCKET=true

# Alternative: browser connects straight to the Node server
# NEXT_PUBLIC_SOCKET_URL=https://your-node-server.example.com:5001
# NEXT_PUBLIC_ENABLE_SOCKET=true
